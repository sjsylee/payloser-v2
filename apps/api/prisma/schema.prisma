generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GroupRole {
  OWNER
  MEMBER
}

enum GroupJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum ActivityType {
  BOWLING
  SCREEN_BASEBALL
  ROCK_PAPER_SCISSORS
}

enum ExpenseKind {
  BETTING_BURDEN
  GENERAL_PARTICIPATION
  LOCAL_RULE_SOLO
  SIDE_BET
}

enum RpsHand {
  ROCK
  PAPER
  SCISSORS
}

model User {
  id              String   @id @default(uuid())
  kakaoId         String?  @unique
  nickname        String
  profileImageUrl String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  groupMembers         GroupMember[]
  joinRequests         GroupJoinRequest[] @relation("UserJoinRequests")
  resolvedJoinRequests GroupJoinRequest[] @relation("ResolvedJoinRequests")
}

model Group {
  id            String   @id @default(uuid())
  name          String
  imageUrl      String?
  coverImageUrl String?
  themeColor    String   @default("#FEE500")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members          GroupMember[]
  sessions         Session[]
  localRulePresets LocalRulePreset[]
  invitations      GroupInvitation[]
  joinRequests     GroupJoinRequest[]
}

model GroupMember {
  id              String    @id @default(uuid())
  groupId         String
  userId          String?
  displayName     String
  profileImageUrl String?
  role            GroupRole @default(MEMBER)
  isActive        Boolean   @default(true)
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  group        Group              @relation(fields: [groupId], references: [id])
  user         User?              @relation(fields: [userId], references: [id])
  joinRequests GroupJoinRequest[]

  @@index([groupId])
  @@index([userId])
}

model GroupInvitation {
  id              String    @id @default(uuid())
  groupId         String
  token           String    @unique
  createdByUserId String
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id])

  @@index([groupId])
  @@index([createdByUserId])
}

model GroupJoinRequest {
  id               String                 @id @default(uuid())
  groupId          String
  userId           String
  status           GroupJoinRequestStatus @default(PENDING)
  requestedAt      DateTime               @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  targetMemberId   String?
  displayName      String?
  updatedAt        DateTime               @updatedAt

  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user         User         @relation("UserJoinRequests", fields: [userId], references: [id])
  resolvedBy   User?        @relation("ResolvedJoinRequests", fields: [resolvedByUserId], references: [id])
  targetMember GroupMember? @relation(fields: [targetMemberId], references: [id], onDelete: SetNull)

  @@index([groupId, status])
  @@index([userId])
  @@index([targetMemberId])
}

model Session {
  id          String       @id @default(uuid())
  groupId     String
  activity    ActivityType
  title       String
  occurredAt  DateTime
  metadata    Json?
  shareToken  String?      @unique
  createdById String?
  updatedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  group        Group         @relation(fields: [groupId], references: [id])
  expenseItems ExpenseItem[]
  rpsRecords   RpsRecord[]

  @@index([groupId, occurredAt])
}

model ExpenseItem {
  id            String      @id @default(uuid())
  sessionId     String
  payerMemberId String
  kind          ExpenseKind
  title         String
  totalAmount   Decimal     @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  session     Session             @relation(fields: [sessionId], references: [id])
  allocations ExpenseAllocation[]

  @@index([sessionId])
  @@index([payerMemberId])
}

model ExpenseAllocation {
  id            String  @id @default(uuid())
  expenseItemId String
  memberId      String
  amount        Decimal @db.Decimal(12, 2)
  rankingAmount Decimal @db.Decimal(12, 2)
  reason        String

  expenseItem ExpenseItem @relation(fields: [expenseItemId], references: [id])

  @@index([expenseItemId])
  @@index([memberId])
}

model LocalRulePreset {
  id        String   @id @default(uuid())
  groupId   String
  name      String
  type      String
  threshold Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id])
}

model RpsRecord {
  id            String   @id @default(uuid())
  sessionId     String
  loserMemberId String
  loserHand     RpsHand
  context       String
  memo          String?
  createdAt     DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([loserMemberId])
}
